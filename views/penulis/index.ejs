<%- include('../partials/head', { css_file: 'dashboard.css' }) %>
<%- include('../partials/navbar', { penulis: penulis }) %>

<main class="main-content">
    <div class="dashboard-header" style="display:flex; justify-content:space-between; align-items:center;">
        <div>
            <h2 class="page-title">Manajemen Penulis</h2>
            <p class="page-sub">Daftar seluruh jurnalis yang terdaftar dalam sistem (Admin Only)</p>
        </div>
        <a href="/dashboard/penulis/create" class="btn-table btn-table-solid" style="text-decoration:none; display:inline-block; margin-bottom:0;">+ Tambah Penulis</a>
    </div>

    <%- include('../partials/messages') %>

    <div class="stat-card" style="padding: 0; overflow: hidden;">
        <div class="table-responsive">
            <table id="tabel-penulis" class="display data-table" style="width:100%">
                <thead>
                    <tr>
                        <th width="5%">ID</th>
                        <th width="30%">Nama</th>
                        <th width="30%">Email</th>
                        <th width="15%">Bergabung</th>
                        <th width="20%">Aksi Admin</th>
                    </tr>
                </thead>
                <tbody>
                    <% if(data && data.length > 0) { %>
                        <% data.forEach(function(item) { %>
                            <tr>
                                <td><%= item.id %></td>
                                <td><strong><%= item.nama %></strong></td>
                                <td><%= item.email %></td>
                                <td><%= new Date(item.created_at).toLocaleDateString('id-ID') %></td>
                                <td>
                                    <div style="display:flex; gap:0.5rem; justify-content:flex-start;">
                                        <a href="/dashboard/penulis/edit/<%= item.id %>" class="btn-table btn-table-outline">Edit</a>
                                        <% if(item.id !== penulis.id) { %>
                                        <a href="/dashboard/penulis/delete/<%= item.id %>" class="btn-table btn-table-solid" style="background:#e53e3e; border-color:#e53e3e;" onclick="return confirm('PERINGATAN CAUTION: Menghapus penulis otomatis menghapus semua KARYA dan BERITA yang telah ia rancang! Konfirmasi hapus permanen?');">Hapus</a>
                                        <% } else { %>
                                        <button class="btn-table btn-table-outline" disabled style="opacity:0.3; cursor:not-allowed;" title="Anda tidak bisa menghapus diri sendiri agar tidak kehilangan hak admin.">Hapus</button>
                                        <% } %>
                                    </div>
                                </td>
                            </tr>
                        <% }); %>
                    <% } else { %>
                        <tr>
                            <td colspan="5" style="text-align: center; padding: 2rem;">Belum ada data penulis lain.</td>
                        </tr>
                    <% } %>
                </tbody>
            </table>
        </div>
    </div>
</main>

<!-- Injeksi DataTables -->
<link rel="stylesheet" href="https://cdn.datatables.net/1.13.7/css/jquery.dataTables.min.css">
<script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
<script src="https://cdn.datatables.net/1.13.7/js/jquery.dataTables.min.js"></script>
<script>
    $(document).ready(function() {
        $('#tabel-penulis').DataTable({
            "language": {
                "url": "//cdn.datatables.net/plug-ins/1.13.7/i18n/id.json"
            },
            "pageLength": 10,
            "ordering": false
        });
    });
</script>

<%- include('../partials/foot') %>
