<%- include('../partials/head', { css_file: 'dashboard.css' }) %>
<%- include('../partials/navbar', { penulis: penulis }) %>

<main class="main-content">
    <div class="dashboard-header" style="display:flex; justify-content:space-between; align-items:center;">
        <div>
            <h2 class="page-title">Edit Berita</h2>
            <p class="page-sub">Perbarui informasi berita</p>
        </div>
        <a href="/dashboard/berita" class="btn-logout" style="border-color:#ccc;">&larr; Kembali</a>
    </div>

    <%- include('../partials/messages') %>

    <div class="stat-card" style="max-width: 800px;">
        <form action="/dashboard/berita/update/<%= berita.id %>" method="POST" enctype="multipart/form-data">
            
            <div style="margin-bottom: 1.5rem;">
                <label for="judul" style="display:block; font-weight:600; margin-bottom:0.5rem; color:#111;">Judul Berita</label>
                <input type="text" id="judul" name="judul" value="<%= berita.judul %>" required maxlength="250" style="width:100%; padding:0.75rem; border:1px solid #ccc; border-radius:4px; font-family:inherit;">
            </div>

            <div style="margin-bottom: 1.5rem;">
                <label for="gambar_berita" style="display:block; font-weight:600; margin-bottom:0.5rem; color:#111;">Gambar Berita (Biarkan kosong jika tidak diubah)</label>
                <% if (berita.gambar_berita) { %>
                    <div style="margin-bottom: 0.5rem;">
                        <% if (berita.gambar_berita.startsWith('http')) { %>
                            <img src="<%= berita.gambar_berita %>" alt="Current Image" style="max-height:100px; border:1px solid #ccc; border-radius:4px;">
                        <% } else { %>
                            <img src="/<%= berita.gambar_berita %>" alt="Current Image" style="max-height:100px; border:1px solid #ccc; border-radius:4px;">
                        <% } %>
                    </div>
                <% } %>
                <div style="margin-bottom: 1.5rem;">
                    <label style="display:block; font-weight:600; margin-bottom:0.5rem; color:#111;">Metode Edit Gambar (Opsional)</label>
                    <div style="margin-bottom: 1rem;">
                        <label style="margin-right: 1.5rem; cursor:pointer;"><input type="radio" name="tipe_gambar" value="upload" checked onchange="toggleImageInput()"> Upload File Baru</label>
                        <label style="cursor:pointer;"><input type="radio" name="tipe_gambar" value="url" onchange="toggleImageInput()"> Ganti via URL</label>
                    </div>

                    <div id="wrap_upload">
                        <input type="file" id="gambar_berita" name="gambar_berita" accept="image/*" style="width:100%; padding:0.5rem; border:1px solid #ccc; border-radius:4px; font-family:inherit;">
                    </div>
                    <div id="wrap_url" style="display:none;">
                        <input type="url" id="gambar_url" name="gambar_url" placeholder="https://..." maxlength="250" style="width:100%; padding:0.75rem; border:1px solid #ccc; border-radius:4px; font-family:inherit;">
                    </div>
                </div>
            </div>

            <div style="margin-bottom: 1.5rem;">
                <label for="isi_berita" style="display:block; font-weight:600; margin-bottom:0.5rem; color:#111;">Isi Berita</label>
                <textarea id="isi_berita" name="isi_berita" rows="10" style="width:100%; padding:0.75rem; border:1px solid #ccc; border-radius:4px; font-family:inherit; resize:vertical;"><%= berita.isi_berita %></textarea>
            </div>

            <div style="display:flex; gap: 1rem; margin-top: 2rem;">
                <button type="submit" class="btn-table btn-table-solid" style="padding: 0.75rem 1.5rem; font-size: 1rem;">Perbarui Berita</button>
                <a href="/dashboard/berita" class="btn-table btn-table-outline" style="padding: 0.65rem 1.5rem; font-size: 1rem;">Batal</a>
            </div>

        </form>

        <script src="https://cdnjs.cloudflare.com/ajax/libs/tinymce/6.8.2/tinymce.min.js" referrerpolicy="origin"></script>
        <script>
            tinymce.init({
                selector: '#isi_berita',
                plugins: 'lists link image preview',
                toolbar: 'undo redo | formatselect | bold italic | alignleft aligncenter alignright | bullist numlist | link',
                menubar: false,
                height: 400,
                branding: false
            });

            function toggleImageInput() {
                const tipe = document.querySelector('input[name="tipe_gambar"]:checked').value;
                const wrapUpload = document.getElementById('wrap_upload');
                const wrapUrl = document.getElementById('wrap_url');
                const uploadInput = document.getElementById('gambar_berita');
                const urlInput = document.getElementById('gambar_url');

                if (tipe === 'upload') {
                    wrapUpload.style.display = 'block';
                    wrapUrl.style.display = 'none';
                    urlInput.value = ''; 
                } else {
                    wrapUpload.style.display = 'none';
                    wrapUrl.style.display = 'block';
                    uploadInput.value = ''; 
                }
            }
        </script>
    </div>
</main>

<%- include('../partials/foot') %>
