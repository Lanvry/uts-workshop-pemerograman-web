<%- include('./partials/head', { css_file: 'dashboard.css' }) %>

<%- include('./partials/navbar', { penulis: penulis }) %> 

<main class="main-content">
    <div class="dashboard-header">
        <h2 class="page-title">Dashboard Penulis</h2>
        <p class="page-sub">Selamat datang kembali, <%= penulis.nama %>!</p>
    </div>

    <%- include('./partials/messages') %>

    <div class="stats-grid">
        <div class="stat-card">
            <div class="stat-icon">📝</div>
            <div class="stat-info">
                <h3>Buat Berita</h3>
                <p>Tulis artikel baru</p>
            </div>
            <a class="stat-link" href="/dashboard/berita/create">Mulai Menulis →</a>
        </div>

        <div class="stat-card">
            <div class="stat-icon">📰</div>
            <div class="stat-info">
                <h3>Berita Saya</h3>
                <p>Total: <strong><%= typeof total_berita !== 'undefined' ? total_berita : 0 %></strong> artikel dipublikasi</p>
            </div>
            <a class="stat-link" href="/dashboard/berita">Lihat Semua →</a>
        </div>

        <div class="stat-card">
            <div class="stat-icon">👤</div>
            <div class="stat-info">
                <h3>Profil</h3>
                <p>Email: <%= penulis.email %></p>
            </div>
            <a class="stat-link" href="/dashboard/profile">Lihat Profil →</a>
        </div>

        <div class="stat-card">
            <div class="stat-icon">🚪</div>
            <div class="stat-info">
                <h3>Keluar</h3>
                <p>Akhiri sesi sekarang</p>
            </div>
            <a class="stat-link" href="/logout">Logout →</a>
        </div>
    </div>
</main>

<%- include('./partials/foot') %>
