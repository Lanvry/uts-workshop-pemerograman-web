<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap">
    <link rel="stylesheet" href="/stylesheets/auth.css">
</head>
<body>
    <div class="auth-wrapper">
        <div class="auth-card">
            <div class="auth-brand">
                <div class="brand-icon">📰</div>
                <h1 class="brand-title">Siberita</h1>
                <p class="brand-sub">Platform Berita Digital</p>
            </div>

            <h2 class="auth-heading">Masuk ke Akun</h2>
            <p class="auth-subheading">Selamat datang kembali, silakan login</p>

            <% if (messages.error) { %>
                <div class="alert alert-error">
                    <span class="alert-icon">⚠️</span>
                    <span><%= messages.error %></span>
                </div>
            <% } %>

            <% if (messages.success) { %>
                <div class="alert alert-success">
                    <span class="alert-icon">✅</span>
                    <span><%= messages.success %></span>
                </div>
            <% } %>

            <form action="/loginSave" method="POST" novalidate>
                <div class="form-group">
                    <label for="email">Email</label>
                    <div class="input-wrapper">
                        <span class="input-icon">📧</span>
                        <input id="email" type="email" name="email" placeholder="nama@email.com" required autocomplete="email">
                    </div>
                </div>

                <div class="form-group">
                    <label for="password">Password</label>
                    <div class="input-wrapper">
                        <span class="input-icon">🔒</span>
                        <input id="password" type="password" name="password" placeholder="Masukkan password" required autocomplete="current-password">
                    </div>
                </div>

                <button class="btn-auth" type="submit">Masuk</button>
            </form>

            <div class="auth-footer">
                <span>Belum punya akun?&nbsp;</span>
                <a href="/register">Daftar Sekarang</a>
            </div>
        </div>
    </div>
</body>
</html>
