<%- include('../partials/head', { css_file: 'auth.css' }) %>

<div class="auth-wrapper">
    <div class="auth-card">
        <div class="auth-brand">
            <div class="brand-icon">📰</div>
            <h1 class="brand-title">Siberita</h1>
            <p class="brand-sub">Platform Berita Digital</p>
        </div>

        <h2 class="auth-heading">Masuk ke Akun</h2>
        <p class="auth-subheading">Selamat datang kembali, silakan login</p>

        <%- include('../partials/messages') %>

        <form action="/loginSave" method="POST" novalidate>
            <div class="form-group">
                <label for="email">Email</label>
                <div class="input-wrapper">
                    <span class="input-icon">📧</span>
                    <input id="email" type="email" name="email" placeholder="nama@email.com" required autocomplete="email">
                </div>
            </div>

            <div class="form-group">
                <label for="password">Password</label>
                <div class="input-wrapper">
                    <span class="input-icon">🔒</span>
                    <input id="password" type="password" name="password" placeholder="Masukkan password" required autocomplete="current-password">
                </div>
            </div>

            <button class="btn-auth" type="submit">Masuk</button>
        </form>

        <div class="auth-footer">
            <span>Belum punya akun?&nbsp;</span>
            <a href="/register">Daftar Sekarang</a>
        </div>
    </div>
</div>

<%- include('../partials/foot') %>
